# Optional overrides for Firebase web config.
# The app already contains committed fallback values so it can run after cloning the repo.
# Keep these only if you need to point a local build to another Firebase project.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: runtime host allowlist (defense-in-depth).
# Comma-separated hostnames where this build is allowed to run.
# This does NOT replace proper API key restrictions in Google Cloud Console.
VITE_ALLOWED_HOSTS=localhost,127.0.0.1

# Project owner UID (superadmin override in app UI)
VITE_SUPERADMIN_UID=

# Absolute superadmin email override
VITE_SUPERADMIN_EMAIL=
